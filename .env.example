# PocketTab environment example
# Copy values into your deployment environment.

PORT=3000
NODE_ENV=development

# Required in all environments (including staging and production).
# Use a random 32+ byte secret.
JWT_SECRET=replace-with-random-jwt-secret

# Required in all environments for PIN peppering.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PIN_PEPPER=replace-with-random-64-hex-characters

# Optional override. In production this should point to durable storage.
DB_PATH=./pockettab.db

ALLOW_DATA_RESET=false
SLOW_REQUEST_MS=1000
JSON_BODY_LIMIT=10mb
TRUST_PROXY=false
SESSION_TTL_DAYS=7
RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

DB_BACKUP_DIR=./backups
DB_BACKUP_KEEP=14
DB_BACKUP_MIN_COUNT=1
DB_BACKUP_MAX_AGE_HOURS=30
